{
    "buildCommand": "npm run build -w shared && npm run build -w client",
    "outputDirectory": "client/dist",
    "installCommand": "npm install",
    "framework": null,
    "trailingSlash": false,
    "rewrites": [
        { "source": "/api/(.*)", "destination": "https://ghess.onrender.com/api/$1" },
        { "source": "/(.*)", "destination": "/apps/features/analysis.html" }
    ],
    "headers": [
        {
            "source": "/(.+\\.wasm)",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/wasm"
                }
            ]
        }
    ]
}
